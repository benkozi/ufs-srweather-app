#!/usr/bin/env bash


#
#-----------------------------------------------------------------------
#
# This J-Job script runs a set of tests at the end of WE2E tests.
#
# Run-time environment variables:
#
#    GLOBAL_VAR_DEFNS_FP
#    CDATE
#    FCST_DIR
#    SLASH_ENSMEM_SUBDIR
#
# Experiment variables
#
#  user:
#    RUN_ENV
#    SCRIPTSdir
#    USHdir
#
#  workflow:
